<?xml version="1.0" encoding="utf-8"?>
<!--
  WhatsMiku icon foreground
  Concept: speech bubble with a spark/star (✦) inside — minimal, clean
  Designed for 108x108dp adaptive icon foreground canvas (safe zone: center 72dp)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Chat bubble shape -->
    <path
        android:fillColor="#00D9FF"
        android:pathData="
            M 28,26
            Q 28,20 34,20
            L 74,20
            Q 80,20 80,26
            L 80,58
            Q 80,64 74,64
            L 48,64
            L 38,76
            L 40,64
            L 34,64
            Q 28,64 28,58
            Z
        "/>

    <!-- Inner white bubble (cutout effect via white overlay) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M 31,27
            Q 31,23 35,23
            L 73,23
            Q 77,23 77,27
            L 77,57
            Q 77,61 73,61
            L 47,61
            L 38.5,72
            L 40,61
            L 35,61
            Q 31,61 31,57
            Z
        "/>

    <!-- Star/spark symbol (✦ shape) inside bubble -->
    <!-- Vertical bar -->
    <path
        android:fillColor="#00D9FF"
        android:pathData="M 52.5,30 L 55.5,30 L 55.5,54 L 52.5,54 Z"/>

    <!-- Horizontal bar -->
    <path
        android:fillColor="#00D9FF"
        android:pathData="M 40,40.5 L 68,40.5 L 68,43.5 L 40,43.5 Z"/>

    <!-- Diagonal top-left to bottom-right -->
    <path
        android:fillColor="#00D9FF"
        android:pathData="M 42.5,31.5 L 44.6,29.4 L 65.5,50.5 L 63.4,52.6 Z"/>

    <!-- Diagonal top-right to bottom-left -->
    <path
        android:fillColor="#00D9FF"
        android:pathData="M 63.5,31.5 L 65.6,29.4 L 44.5,50.5 L 42.4,52.6 Z"/>

    <!-- Small cyan dot - status indicator bottom right -->
    <path
        android:fillColor="#25D366"
        android:pathData="M 74,70 A 5,5 0 1,1 74.001,70 Z"/>

</vector>
