<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D1A">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#10022;"
                android:textSize="28sp"
                android:textColor="#00D9FF"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:id="@+id/titleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WhatsMiku"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WhatsApp Auto-Reply + Floating Window"
            android:textSize="13sp"
            android:textColor="#5588AA"
            android:layout_marginBottom="28dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1A1A2E"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Setup"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="#00D9FF"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.  Aktifkan Notification Access\n2.  Jalankan Termux bot\n3.  Aktifkan Floating Window\n4.  Kirim WA untuk test"
                    android:textSize="13sp"
                    android:textColor="#99BBCC"
                    android:lineSpacingExtra="4dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btnEnable"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Aktifkan Notification Access"
            android:backgroundTint="#25D366"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="12dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1A1A2E"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Floating Window"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="#FFFFFF"/>

                    <TextView
                        android:id="@+id/tvFloatStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="OFF"
                        android:textSize="12sp"
                        android:textColor="#AAAAAA"/>

                </LinearLayout>

                <Button
                    android:id="@+id/btnFloat"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:text="Toggle Floating Window"
                    android:backgroundTint="#00D9FF"
                    android:textColor="#0D0D1A"
                    android:textStyle="bold"
                    android:textSize="13sp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Drag untuk pindah. Minimize ke bubble. Tap X untuk tutup."
            android:textSize="11sp"
            android:textColor="#445566"
            android:gravity="center"
            android:layout_gravity="center"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
